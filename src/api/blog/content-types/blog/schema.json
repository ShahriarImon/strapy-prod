{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "Description": {
      "type": "blocks"
    },
    "date": {
      "type": "date",
      "required": true
    },
    "blogImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "blogItem": {
      "type": "component",
      "component": "shared.blog-item",
      "repeatable": true
    }
  }
}
